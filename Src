-- [[ CONFIG ]]
local Config = {
    AutoLuckySpins = false,
    AutoAbilitySpins = false,

    --========================================================--
    -- EDIT THIS NUMBER TO CHANGE THE MAX TOTAL SPINS ALLOWED --
    -- Example: 20 = script stops after 20 total spins       --
    -- Set to math.huge for unlimited spins                  --
    --========================================================--
    MaxSpins = 20,
}

-- [[ CORE REQS & SERVICES ]]
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

-- [[ DUPLICATE PROTECTION CHECK ]]
if CoreGui:FindFirstChild("SpinManagerUI") or Player:WaitForChild("PlayerGui"):FindFirstChild("SpinManagerUI") then
    warn("[Spin Manager]: Script is already running! Blocked duplicate execution.")
    return
end

-- [[ TARGET REMOTE FUNCTION ]]
local remote = ReplicatedStorage:WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")
    :WaitForChild("Services")
    :WaitForChild("SeasonService")
    :WaitForChild("RF")
    :WaitForChild("RequestRankedReward")

-- [[ TRACKERS & PACING RATES ]]
local TotalSpinsExecuted = 0
local WindowSpins = 0
local WindowResetTime = os.clock() + 5

-- Shared throttling check
local function checkRateLimit()
    local currentTime = os.clock()
    if currentTime >= WindowResetTime then
        WindowSpins = 0
        WindowResetTime = currentTime + 5
    end
    return WindowSpins < 2
end

