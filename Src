-- [[ TRACKERS & PACING RATES ]]
local TotalSpinsExecuted = 0
local WindowSpins = 0
local WindowResetTime = os.clock() + 5
local ScannedItemDatabase = {} -- Stores discovered Name -> ID mappings

local function checkRateLimit()
    local currentTime = os.clock()
    if currentTime >= WindowResetTime then
        WindowSpins = 0
        WindowResetTime = currentTime + 5
    end
    return WindowSpins < 2
end

-- [[ SOURCE CODE / MODULE SCANNER ENGINE ]]
local function scanGameSource()
    local foundCount = 0
    local checkedModules = 0
    ScannedItemDatabase = {} -- Reset database
    
    print("[Scanner]: Beginning deep scan of game assets and modules...")
    
    -- Deep scan strategy 1: Read returned data tables from ModuleScripts
    for _, module in ipairs(ReplicatedStorage:GetDescendants()) do
        if module:IsA("ModuleScript") then
            checkedModules = checkedModules + 1
            local success, dataTable = pcall(function()
                return require(module)
            end)
            
            if success and type(dataTable) == "table" then
                -- Recursive function to parse deeply nested game data tables
                local function parseTable(t)
                    for key, val in pairs(t) do
                        local cleanKey = tostring(key):lower():gsub("[%-_%s]", "")
                        local cleanVal = tostring(val):lower():gsub("[%-_%s]", "")
                        
                        -- Pattern Match A: Key is a string name, Value is a number ID
                        if type(key) == "string" and type(val) == "number" and val <= 100000 then
                            if not ScannedItemDatabase[cleanKey] then
                                ScannedItemDatabase[cleanKey] = val
                                foundCount = foundCount + 1
                            end
                        -- Pattern Match B: Standard dictionary structure {Name = "Blackball", Id = 7}
                        elseif type(val) == "table" then
                            local id = val.Id or val.ID or val.id or val.ItemId or val.AssetId
                            local name = val.Name or val.Name or val.name or val.ItemName
                            
                            if tonumber(id) and type(name) == "string" then
                                local cName = name:lower():gsub("[%-_%s]", "")
                                if not ScannedItemDatabase[cName] then
                                    ScannedItemDatabase[cName] = tonumber(id)
                                    foundCount = foundCount + 1
                                end
                            else
                                parseTable(val) -- Recurse deeper if it's just another folder/table
                            end
                        end
                    end
                end
                parseTable(dataTable)
            end
        end
    end
    
    -- Deep scan strategy 2: Scan Instance Objects and Value objects
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("ValueBase") and tonumber(obj.Value) then
            local cleanName = obj.Name:lower():gsub("[%-_%s]", "")
            if not ScannedItemDatabase[cleanName] then
                ScannedItemDatabase[cleanName] = tonumber(obj.Value)
                foundCount = foundCount + 1
            end
        end
    end
    
    print("[Scanner]: Scan complete. Analyzed " .. checkedModules .. " modules. Mapped " .. foundCount .. " unique items to numerical IDs.")
    return foundCount
end

