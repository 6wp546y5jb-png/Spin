-- [[ HELPER: CASING PERMUTATION GENERATOR ]]
local function getCasingPermutations(input)
    -- Clean whitespaces and symbols, isolate structural words
    local words = {}
    for word in string.gmatch(input, "[%w]+") do
        table.insert(words, word)
    end
    
    if #words == 0 then return {input} end

    -- Reconstruct into different string formats
    local rawLower = string.lower(input)
    local rawUpper = string.upper(input)
    
    -- Snake Case (neon_ball)
    local snakeCase = string.lower(table.concat(words, "_"))
    
    -- Camel Case (neonBall)
    local camelCase = string.lower(words[1])
    for i = 2, #words do
        camelCase = camelCase .. string.upper(string.sub(words[i], 1, 1)) .. string.lower(string.sub(words[i], 2))
    end
    
    -- Pascal Case (NeonBall)
    local pascalCase = ""
    for i = 1, #words do
        pascalCase = pascalCase .. string.upper(string.sub(words[i], 1, 1)) .. string.lower(string.sub(words[i], 2))
    end
    
    -- Space separated cleanly
    local normalSpaced = table.concat(words, " ")

    -- Remove duplicates dynamically
    local unique = {}
    local results = {}
    for _, str in ipairs({input, rawLower, rawUpper, snakeCase, camelCase, pascalCase, normalSpaced}) do
        if not unique[str] then
            unique[str] = true
            table.insert(results, str)
        end
    end
    return results
end

-- [[ PROCESS GENERATION VIA FORMAT MATRICES ]]
GenButton.MouseButton1Click:Connect(function()
    local rawInput = TyperBox.Text
    if rawInput == "" then
        GenStatus.Text = "Status: Input field empty."
        GenStatus.TextColor3 = Color3.fromRGB(220, 80, 80)
        return
    end

    GenStatus.Text = "Status: Formulating permutation arrays..."
    GenStatus.TextColor3 = Color3.fromRGB(200, 200, 100)

    -- Collect every casing alternative
    local baseStrings = getCasingPermutations(rawInput)
    local finalPayloads = {}

    -- Handle number-specific padding if input happens to be a standalone number
    local num = tonumber(rawInput)
    if num then
        table.insert(finalPayloads, num)
        table.insert(finalPayloads, string.format("%03d", num))
    end

    -- Wrap casing types inside multiple structural developer dictionary keys
    for _, str in ipairs(baseStrings) do
        table.insert(finalPayloads, str)                     -- Direct String literal
        table.insert(finalPayloads, {ID = str})               -- Standard Hash ID object
        table.insert(finalPayloads, {Item = str})             -- Standard Name Object
        table.insert(finalPayloads, {Name = str})             -- Direct item reference
        table.insert(finalPayloads, {AssetID = str})          -- Asset Tag key
        table.insert(finalPayloads, {str})                    -- Linear Array formatting
    end

    -- Run structural firing down pipelines
    task.spawn(function()
        for _, payload in ipairs(finalPayloads) do
            pcall(function()
                remote:InvokeServer(payload)
                remote:InvokeServer("ItemRequest", payload)
                remote:InvokeServer(1, payload) -- Double verification argument pattern
            end)
            task.wait(0.04) -- Pacing to handle the array density safely
        end
        GenStatus.Text = "Status: Finished scanning variant branches."
        GenStatus.TextColor3 = Color3.fromRGB(80, 220, 80)
    end)
end)

