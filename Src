-- Multi-style Remote Scanning Execution
SearchButton.MouseButton1Click:Connect(function()
    local textInput = SearchInput.Text
    if textInput == "" then return end
    
    local scanItems = getAllFormatStyles(textInput)
    
    if #scanItems > 0 then
        if TotalSpinsExecuted < Config.MaxSpins and checkRateLimit() then
            WindowSpins = WindowSpins + 1
            TotalSpinsExecuted = TotalSpinsExecuted + 1
            StatusLabel.Text = "Total Spins: " .. TotalSpinsExecuted .. " / " .. tostring(Config.MaxSpins)
            
            TweenService:Create(SearchButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 70, 110)}):Play()
            task.delay(0.1, function()
                TweenService:Create(SearchButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(60, 100, 160)}):Play()
            end)

            task.spawn(function()
                -- Sequentially hits the remote using every variation format found
                for _, formatVariant in ipairs(scanItems) do
                    local success, err = pcall(function() 
                        remote:InvokeServer(formatVariant) 
                    end)
                    if not success then
                        warn("Failed dispatch for variant style ["..tostring(formatVariant).."]: " .. tostring(err))
                    end
                end
            end)
        else
            warn("Rate limit reached or Max Spins exceeded.")
        end
    end
end)

