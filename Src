-- Helper Function for Creating Toggles
local function createToggle(name, text, posY, configKey)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -40, 0, 45)
    Container.Position = UDim2.new(0, 20, 0, posY)
    Container.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    Container.BorderSizePixel = 0
    Container.Parent = MainFrame
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Container

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(220, 220, 225)
    Label.TextSize = 15
    Label.Font = Enum.Font.SourceSansSemibold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 60, 0, 25)
    Button.Position = UDim2.new(1, -75, 0.5, -12)
    Button.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Button.Text = "OFF"
    Button.TextColor3 = Color3.fromRGB(200, 70, 70)
    Button.Font = Enum.Font.SourceSansBold
    Button.TextSize = 12
    Button.Parent = Container
    
    local BCorner = Instance.new("UICorner")
    BCorner.CornerRadius = UDim.new(0, 4)
    BCorner.Parent = Button

    Button.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        if Config[configKey] then
            Button.Text = "ON"
            Button.TextColor3 = Color3.fromRGB(70, 200, 70)
            TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 65, 45)}):Play()
        else
            Button.Text = "OFF"
            Button.TextColor3 = Color3.fromRGB(200, 70, 70)
            TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 55)}):Play()
        end
    end)
end

-- Helper Function for Creating Input Boxes
local function createTextBox(text, posY, placeholder, callback)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -40, 0, 45)
    Container.Position = UDim2.new(0, 20, 0, posY)
    Container.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    Container.BorderSizePixel = 0
    Container.Parent = MainFrame
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 6)
    Corner.Parent = Container

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(220, 220, 225)
    Label.TextSize = 14
    Label.Font = Enum.Font.SourceSans
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(0, 80, 0, 25)
    Box.Position = UDim2.new(1, -95, 0.5, -12)
    Box.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    Box.TextColor3 = Color3.fromRGB(255, 255, 255)
    Box.Text = placeholder
    Box.Font = Enum.Font.SourceSans
    Box.TextSize = 14
    Box.Parent = Container
    
    local BCorner = Instance.new("UICorner")
    BCorner.CornerRadius = UDim.new(0, 4)
    BCorner.Parent = Box

    Box.FocusLost:Connect(function(enterPressed)
        local val = tonumber(Box.Text)
        if val then
            callback(val)
        else
            Box.Text = placeholder
        end
    end)
end

-- Build Interface Rows
createToggle("LuckyToggle", "Auto Lucky Spins", 100, "AutoLuckySpins")
createTextBox("Lucky Delay (s):", 155, tostring(Config.LuckyDelay), function(val) Config.LuckyDelay = val end)

createToggle("AbilityToggle", "Auto Ability Spins", 215, "AutoAbilitySpins")
createTextBox("Ability Delay (s):", 270, tostring(Config.AbilityDelay), function(val) Config.AbilityDelay = val end)

createTextBox("Max Total Spins:", 330, tostring(Config.MaxSpins), function(val) 
    Config.MaxSpins = val 
    StatusLabel.Text = "Total Spins: " .. TotalSpinsExecuted .. " / " .. Config.MaxSpins
end)


-- [[ EXECUTION LOOPS WITH COMBINED SPIN LIMITER ]]

-- Loop 1: Lucky Spins
task.spawn(function()
    while true do
        if Config.AutoLuckySpins and TotalSpinsExecuted < Config.MaxSpins then
            -- Increment BEFORE invocation to avoid race conditions between fast loops
            TotalSpinsExecuted = TotalSpinsExecuted + 1
            StatusLabel.Text = "Total Spins: " .. TotalSpinsExecuted .. " / " .. Config.MaxSpins
            
            local success, err = pcall(function() 
                remote:InvokeServer(1) 
            end)
            
            if not success then
                warn("Lucky Spin Error: " .. tostring(err))
            end
        end
        task.wait(Config.LuckyDelay)
    end
end)

-- Loop 2: Ability Spins
task.spawn(function()
    while true do
        if Config.AutoAbilitySpins and TotalSpinsExecuted < Config.MaxSpins then
            -- Increment BEFORE invocation to avoid race conditions between fast loops
            TotalSpinsExecuted = TotalSpinsExecuted + 1
            StatusLabel.Text = "Total Spins: " .. TotalSpinsExecuted .. " / " .. Config.MaxSpins
            
            local success, err = pcall(function() 
                remote:InvokeServer(4) 
            end)
            
            if not success then
                warn("Ability Spin Error: " .. tostring(err))
            end
        end
        task.wait(Config.AbilityDelay)
    end
end)
