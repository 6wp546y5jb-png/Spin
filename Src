SearchButton.MouseButton1Click:Connect(function()
    local textInput = SearchInput.Text
    if textInput == "" then return end
    
    local targetedId = tonumber(textInput)
    
    -- If it isn't an explicit integer, look it up inside our newly scanned database
    if not targetedId then
        local normalizedSearch = textInput:lower():gsub("[%-_%s]", "")
        targetedId = ScannedItemDatabase[normalizedSearch]
    end
    
    if targetedId then
        if TotalSpinsExecuted < Config.MaxSpins and checkRateLimit() then
            WindowSpins = WindowSpins + 1
            TotalSpinsExecuted = TotalSpinsExecuted + 1
            StatusLabel.Text = "Total Spins: " .. TotalSpinsExecuted .. " / " .. tostring(Config.MaxSpins)
            
            TweenService:Create(SearchButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40, 70, 110)}):Play()
            task.delay(0.1, function()
                TweenService:Create(SearchButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(60, 100, 160)}):Play()
            end)

            task.spawn(function()
                local success, err = pcall(function() 
                    remote:InvokeServer(targetedId) 
                end)
                if not success then
                    warn("Server rejected looked-up ID ("..tostring(targetedId).."): " .. tostring(err))
                end
            end)
        else
            warn("Rate limit or Max Spins reached.")
        end
    else
        warn("Item name not found in current database. Click 'SCAN GAME' first!")
        SearchInput.Text = ""
        SearchInput.PlaceholderText = "Run Scan First!"
        task.delay(1.5, function() SearchInput.PlaceholderText = "Enter item name..." end)
    end
end)

