-- [[ TRACKERS & PACING RATES ]]
local TotalSpinsExecuted = 0
local WindowSpins = 0
local WindowResetTime = os.clock() + 5

local function checkRateLimit()
    local currentTime = os.clock()
    if currentTime >= WindowResetTime then
        WindowSpins = 0
        WindowResetTime = currentTime + 5
    end
    return WindowSpins < 2
end

