-- [[ TRACKERS & PACING RATES ]]
local TotalSpinsExecuted = 0
local WindowSpins = 0
local WindowResetTime = os.clock() + 5

-- Shared throttling check
local function checkRateLimit()
    local currentTime = os.clock()
    if currentTime >= WindowResetTime then
        WindowSpins = 0
        WindowResetTime = currentTime + 5
    end
    return WindowSpins < 2
end

-- [[ COMPREHENSIVE SCANNING FORMATTER ]]
local function getAllFormatStyles(inputStr)
    local variants = {}
    local seen = {}
    
    local function add(val)
        if val and val ~= "" and not seen[val] then
            seen[val] = true
            table.insert(variants, val)
        end
    end
    
    -- Clean edge spaces
    inputStr = inputStr:gsub("^%s*(.-)%s*$", "%1")
    if tonumber(inputStr) then return {tonumber(inputStr)} end

    -- Extract words regardless of dividers (spaces, underscores, hyphens, camelCase casing)
    local words = {}
    -- Split up camelCase/PascalCase words safely
    local brokenCasing = inputStr:gsub("(%l)(%u)", "%1 %2"):gsub("(%u)(%u%l)", "%1 %2")
    -- Collect individual word sequences
    for word in brokenCasing:gsub("[%-_%s]+", " "):gmatch("%S+") do
        table.insert(words, word)
    end
    
    if #words == 0 then return {inputStr} end
    
    -- 1. Raw exact text
    add(inputStr)
    
    -- 2. Lowercase & Uppercase raw
    add(inputStr:lower())
    add(inputStr:upper())
    
    -- 3. Formatted Styles across word components
    local lowerWords, upperWords, titleWords = {}, {}, {}
    for i, w in ipairs(words) do
        lowerWords[i] = w:lower()
        upperWords[i] = w:upper()
        titleWords[i] = w:sub(1,1):upper() .. w:sub(2):lower()
    end
    
    -- Flat Concatenations (e.g., blackball, BlackBall)
    add(table.concat(lowerWords))
    add(table.concat(upperWords))
    add(table.concat(titleWords)) -- PascalCase
    if #titleWords > 0 then
        titleWords[1] = titleWords[1]:lower()
        add(table.concat(titleWords)) -- camelCase
    end
    
    -- Snake Case variants (e.g., black_ball, BLACK_BALL)
    add(table.concat(lowerWords, "_"))
    add(table.concat(upperWords, "_"))
    
    -- Kebab Case variants (e.g., black-ball, BLACK-BALL)
    add(table.concat(lowerWords, "-"))
    add(table.concat(upperWords, "-"))
    
    -- Space separated variants (e.g., black ball, Black Ball)
    add(table.concat(lowerWords, " "))
    add(table.concat(upperWords, " "))
    
    return variants
end

